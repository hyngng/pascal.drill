<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Pascal.Views.SubPages.WindowsUpdateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Pascal.Views.SubPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
    TO-DO:
    
    1. 해상도에 따라 폰트 크기 조절하기
    
    2. 모니터를 복수개로 사용할 경우
    모든 모니터에 대해 창 띄우기
    
    2.
    "업데이트가 진행 중입니다", "업데이트 진행 중 74%", "다시 시작 중입니다"
    주기 만들기
    -->

    <Grid Background="#000000" KeyDown="Window_KeyDown">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <dev:ProgressRing IsActive="True"
                              Foreground="#FFFFFFFF"
                              Width="60"
                              Height="60"/>
            <TextBlock Text="업데이트가 진행 중입니다."
                       Foreground="#FFFFFFFF"
                       FontSize="20"
                       TextAlignment="Center" />
            <TextBlock Text="컴퓨터를 계속 켜 두세요."
                       Foreground="#FFFFFFFF"
                       FontSize="20"
                       TextAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
