<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Pascal.Views.Pages.PdfEditPages.PdfMergePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Pascal.Views.Pages.PdfEditPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:models="using:Pascal.Models"
    xmlns:dev="using:DevWinUI"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" MaxWidth="1064">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>
        <StackPanel
            dev:PanelAttach.ChildrenTransitions="Default"
            Spacing="12"
            Grid.Row="0">
            <TextBlock
                x:Name="PageHeader"
                Margin="{ThemeResource PageHeaderMargin}"
                Padding="{ThemeResource PageHeaderPadding}"
                Style="{StaticResource TitleTextBlockStyle}"
                AutomationProperties.HeadingLevel="Level1"
                Text="PDF 병합하기" />
            <TextBlock
                x:Name="PageDescription"
                Margin="{ThemeResource PageDescriptionMargin}"
                Padding="{ThemeResource PageDescriptionPadding}"
                Style="{StaticResource CaptionTextBlockStyle}"
                AutomationProperties.HeadingLevel="Level1"
                Text="여러 PDF 파일을 하나로 합칠 수 있습니다." />
            <CommandBar
                Background="Transparent"
                IsOpen="False"
                DefaultLabelPosition="Right"
                Margin="36,0">
                <AppBarButton
                    x:Name="PickPdfFilesButton"
                    Icon="Add"
                    Label="불러오기"
                    ToolTipService.ToolTip="PDF 파일을 목록에 추가합니다"
                    Command="{x:Bind ViewModel.AddPdfFilesCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}" />
                <AppBarButton
                    x:Name="SaveAMergedPdfFileButton"
                    Icon="Save"
                    Label="저장하기"
                    ToolTipService.ToolTip="추가된 PDF 파일을 하나로 병합합니다"
                    Command="{x:Bind ViewModel.SavePdfFileCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}" />
            </CommandBar>
        </StackPanel>
        <Border
            Style="{ThemeResource InfoBorderPanelStyle}" 
            Margin="36,0"
            Padding="16"
            Grid.Row="1">
            <ListView
                x:Name="PdfListView"
                ItemsSource="{x:Bind ViewModel.PdfItems, Mode=OneWay}"
                DragOver="PdfListView_OnDragOver"
                Drop="PdfListView_OnDrop"
                SelectionMode="Extended"
                CanReorderItems="True"
                CanDragItems="True"
                AllowDrop="True">
                <ListView.Header>
                    <Grid
                        Background="{ThemeResource TableIndexBackgroundColor}"
                        ColumnSpacing="16"
                        Padding="8,8,8,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>
                        <interactivity:Interaction.Behaviors>
                            <behaviors:StickyHeaderBehavior />
                        </interactivity:Interaction.Behaviors>
                        <TextBlock
                            Grid.Column="0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="연번" />
                        <TextBlock
                            Grid.Column="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="파일명" />
                        <TextBlock
                            Grid.Column="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="병합 범위" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PdfItem">
                        <Grid
                            VerticalAlignment="Center"
                            ColumnSpacing="16"
                            Padding="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind FileOrder, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind FileName, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                VerticalAlignment="Center" />
                            <TextBox
                                Grid.Column="2"
                                Text="{x:Bind PageRange, Mode=TwoWay}"
                                PlaceholderText="{x:Bind PageRangeHint, Mode=OneWay}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="ContextFlyout">
                            <Setter.Value>
                                <MenuFlyout Opening="ItemMenuFlyout_Opening">
                                    <MenuFlyoutItem
                                        x:Name="OpenMenu"
                                        Text="열기"
                                        Icon="OpenFile"
                                        Tag="OpenMenu" />
                                    <MenuFlyoutSeparator x:Name="FlyoutSeperator" />
                                    <MenuFlyoutItem
                                        x:Name="DeleteMenu"
                                        Text="삭제"
                                        Icon="Delete"
                                        Tag="DeleteMenu">
                                        <MenuFlyoutItem.KeyboardAccelerators>
                                            <!--<KeyboardAccelerator Key="Delete" />-->
                                        </MenuFlyoutItem.KeyboardAccelerators>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>
