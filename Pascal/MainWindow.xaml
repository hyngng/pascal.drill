<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Pascal.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dev="using:DevWinUI"
        xmlns:local="using:Pascal"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="using:Pascal.Views.Pages"
        xmlns:pdfPages="using:Pascal.Views.Pages.PdfEditPages"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="AppTitleBar"
            Title="{x:Bind dev:ProcessInfoHelper.ProductName}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <!--  Temporary Fix TitleBar Icon  -->
            <TitleBar.LeftHeader>
                <ImageIcon Width="16"
                           Height="16"
                           Margin="20,0,14,0"
                           Source="ms-appx:///Assets/AppIcon.png" />
            </TitleBar.LeftHeader>
        </TitleBar>
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="HomePage"
                    Content="홈페이지"
                    Icon="Home"
                    dev:NavigationServiceEx.NavigateTo="pages:HomeLandingPage" />
                <NavigationViewItemSeparator/>
                <NavigationViewItem
                    x:Name="PdfEditPages"
                    Content="PDF 편집"
                    Icon="TwoPage"
                    SelectsOnInvoked="False">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem
                            x:Name="PdfMergePage"
                            Content="PDF 병합 페이지"
                            Icon="Page2"
                            dev:NavigationServiceEx.NavigateTo="pdfPages:PdfMergePage" />
                        <NavigationViewItem
                            x:Name="PdfSplitPage"
                            Content="PDF 분할 페이지" 
                            Icon="Page2"
                            dev:NavigationServiceEx.NavigateTo="pdfPages:PdfSplitPage" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="LabsPage"
                    Content="아직 만드는 중"
                    Icon="Emoji"
                    Visibility="{x:Bind ViewModel.IsLabsVisible, Mode=OneWay}"
                    dev:NavigationServiceEx.NavigateTo="pages:WindowsUpdatePage" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    x:Name="CreditPage"
                    Content="크레딧"
                    Icon="OutlineStar"
                    dev:NavigationServiceEx.NavigateTo="pages:CreditPage" />
            </NavigationView.FooterMenuItems>
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>

